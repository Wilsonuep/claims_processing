# ============================================================
# claims_processing — .env template
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# --- LLM Backend ---
LLM_BACKEND=together
LLM_MODEL=openai/gpt-oss-20b
# LLM_BASE_URL=http://localhost:11434/v1   # Ollama / vLLM override

together_api_key=YOUR_TOGETHER_API_KEY_HERE

# --- Monitoring (brrr push notifications) ---
# Set to "true" to enable, "false" to disable.
MONITORING_ACTIVE=true

# Your brrr webhook URL (found inside the brrr app).
# Anyone with this URL can push notifications to your device — keep it private!
BRRR_WEBHOOK_URL=https://api.brrr.now/v1/YOUR_SECRET_HERE

# Human-readable name for this machine (included in every notification).
MACHINE_NAME=my-eval-machine
